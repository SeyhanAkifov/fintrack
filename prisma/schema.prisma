generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  income
  expense
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id        Int             @id @default(autoincrement())
  amount    Float
  type      TransactionType
  category  String
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())
  userId    Int?
  user      User?           @relation(fields: [userId], references: [id])
}
