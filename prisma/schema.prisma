generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  income
  expense
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  budgets      Budget[]
  categories   Category[]
}

model Category {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  name      String
  color     String
  icon      String
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Budget {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  category    String
  limitAmount Float
  month       Int
  year        Int
  createdAt   DateTime @default(now())

  @@unique([userId, category, month, year])
}

model Transaction {
  id        Int             @id @default(autoincrement())
  amount    Float
  type      TransactionType
  category  String
  date      DateTime
  note      String?
  createdAt DateTime        @default(now())
  userId    Int?
  user      User?           @relation(fields: [userId], references: [id])
}
